{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",

    "baseUrl": "./src",
    "paths": {
      "@functions": ["./functions/index.ts"],
      "@constants": ["./constants/index.ts"]
    },
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}